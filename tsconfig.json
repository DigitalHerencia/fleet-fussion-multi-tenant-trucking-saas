{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/styles/*": [
        "./styles/*"
      ],
      "@/components/*": [
        "./components/*"
      ],
      "@/lib/*": [
        "./lib/*"
      ],
      "@/types/*": [
        "./types/*"
      ],
      "@/hooks/*": [
        "./hooks/*"
      ],
      "@/features/*": [
        "./features/*"
      ],
      "@app/*": [
        "./app/*"
      ],
      "@/db/*": [
        "./db/*"
      ],
      "@/db": [
        "./db/index.ts"
      ],
      "@/utils/*": [
        "./utils/*"
      ],
      "@/docs/*": [
        "./docs/*"
      ],
      "@/public/*": [
        "./public/*"
      ],
      "@/context/*": [
        "./context/*"
      ],
      "@/settings/*": [
        "./settings/*"
      ],
      "@/dashboard/*": [
        "./app/dashboard/*"
      ],
      "@/ui/*": [
        "./components/ui/*"
      ],
      "@/actions/*": [
        "./lib/actions/*"
      ],
      "@/constants/*": [
        "./lib/constants/*"
      ],
      "@/fetchers/*": [
        "./lib/fetchers/*"
      ],
      "@/validations/*": [
        "./lib/validations/*"
      ],
      "@/dashboard/[companyId]/*": [
        "./app/dashboard/[companyId]/*"
      ]
    },
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true    },
  "exclude": [
    "node_modules",
    ".next",
    "out"
  ],
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    "app/**/*",
    "components/**/*",
    "postcss.config.mjs",
    "tailwind.config.ts",
    "lib/**/*",
    "hooks/**/*",
    "features/**/*",
    "types/**/*",
    "utils/**/*",
    "docs/**/*",
    "public/**/*",
    "context/**/*",
    "settings/**/*",
    "db/**/*",
    "actions/**/*",
    "constants/**/*",
    "fetchers/**/*",
    "validations/**/*",
    "dashboard/**/*",
    "next.config.ts"
  ]
}
